{
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "Database": {
    "Provider": "PostgreSQL",
    "RunMigrations": false
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "MessageScheduler": {
    "BaseIntervalMinutes": 5,
    "JitterSecondsMax": 20,
    "BatchSizeReserva": 50
  },
  "EscalaScheduler": {
    "Enabled": true,
    "BaseIntervalMinutes": 30,
    "JitterSecondsMax": 20,
    "DiasJanelaInicio": 0,
    "DiasJanelaFim": 60
  },
  "EvolutionApi": {
    "BaseUrl": "https://evolution.kingdombr.com.br",
    "ApiKey": "",
    "InstanceName": "kingdom",
    "TimeoutSeconds": 30,
    "MaxRetries": 3,
    "RetryDelaySeconds": 5,
    "CodigoPaisPadrao": "55"
  }
}

