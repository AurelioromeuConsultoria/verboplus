# ============================================
# Evolution API - Configuração Local
# ============================================
# 
# INSTRUÇÕES:
# 1. Copie este arquivo para .env.evolution
# 2. Substitua os valores abaixo pelos seus valores reais
# 3. NUNCA commite o arquivo .env.evolution no Git!
#
# ============================================

# --------------------------------------------
# Autenticação
# --------------------------------------------
# Gere uma chave segura (ex: openssl rand -hex 32)
AUTHENTICATION_API_KEY=SUA_CHAVE_API_SEGURA_AQUI

# --------------------------------------------
# Banco de Dados PostgreSQL
# --------------------------------------------
DATABASE_ENABLED=true
DATABASE_PROVIDER=postgresql
# Formato: postgresql://usuario:senha@host:porta/database
DATABASE_CONNECTION_URI=postgresql://evolution:evolution123@postgres:5432/evolution

# --------------------------------------------
# Redis (Cache e Filas)
# --------------------------------------------
REDIS_ENABLED=true
# Formato: redis://host:porta ou rediss://host:porta (com SSL)
REDIS_URI=redis://redis:6379

# --------------------------------------------
# URL do Servidor
# --------------------------------------------
# URL pública onde a API estará acessível
# Para local: http://localhost:8080
# Para produção: https://seu-dominio.com
SERVER_URL=http://localhost:8080

# --------------------------------------------
# Configurações da Sessão WhatsApp
# --------------------------------------------
CONFIG_SESSION_PHONE_CLIENT=Chrome
CONFIG_SESSION_PHONE_NAME=Evolution API Local

# --------------------------------------------
# Webhooks
# --------------------------------------------
# Habilita webhooks globais
CONFIG_WEBHOOK_GLOBAL_ENABLED=true

# URL da sua API .NET para receber webhooks
# Ajuste quando implementar os webhooks
CONFIG_WEBHOOK_GLOBAL_URL=http://localhost:7000/api/webhooks/evolution

# Enviar webhook por evento (true) ou todos juntos (false)
CONFIG_WEBHOOK_GLOBAL_WEBHOOK_BY_EVENTS=false

# --------------------------------------------
# Configurações de Log
# --------------------------------------------
# Níveis: ERROR, WARN, INFO, DEBUG, SILLY
LOG_LEVEL=ERROR
LOG_COLOR=false
LOG_BAILEYS=error

# --------------------------------------------
# Configurações Opcionais
# --------------------------------------------
# Timeout para requisições (em ms)
# REQUEST_DELAY=0

# Configurações de QR Code
# QRCODE_LIMIT=30

# Configurações de upload
# CONFIG_MAX_SIZE_UPLOAD=10
